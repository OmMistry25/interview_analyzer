# Supabase (server/worker)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (Next.js browser — NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Fathom
FATHOM_WEBHOOK_SECRET=whsec_your-secret
FATHOM_API_KEY=your-fathom-api-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Apollo.io — optional; worker calls Organization Enrich **only** for estimated employee count → enterprise vs mid_tier.
# Prospect **display name** is derived from attendee email domain + meeting title (no Apollo org name).
# https://apollo.io/api (API key in dashboard → Integrations / API)
APOLLO_API_KEY=your-apollo-api-key

# AE deal brief — **on by default** (omit these vars). Set to false only to disable.
# Worker: false = no extra LLM, omits deal_brief_json from insert (no DB column needed).
#DEAL_BRIEF_ENABLED=false

# Vercel: false = do not select deal_brief_json / hide AE Brief tab.
#NEXT_PUBLIC_DEAL_BRIEF_UI_ENABLED=false
