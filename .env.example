# Supabase (server/worker)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (Next.js browser — NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Fathom
FATHOM_WEBHOOK_SECRET=whsec_your-secret
FATHOM_API_KEY=your-fathom-api-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# AE deal brief (worker: extra LLM + optional DB column). Omit/false = legacy prod behavior.
# Railway worker: leave unset or false until migration + you want the feature.
DEAL_BRIEF_ENABLED=false

# Show AE Brief tab and query deal_brief_json (Vercel). Requires DB column + worker writing briefs.
NEXT_PUBLIC_DEAL_BRIEF_UI_ENABLED=false
